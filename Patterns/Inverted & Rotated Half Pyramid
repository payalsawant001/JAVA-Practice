public class Star {
  public static void main(String args[]) {
    int n = 4;
    for (int Row = 1; Row <= n; Row++) {
      // Spaces
      for (int i = 1; i <= n - Row; i++) {
        System.out.print(" ");
      }
      // Stars
      for (int i = 1; i <= Row; i++) {
        System.out.print("*");
      }
      System.out.println();
    }
  }
}
