public class RightPascalsTriangle {

    public static void main(String[] args) {
        int n = 5; // number of rows

        for (int i = 1; i <= n; i++) {

            // Print leading spaces
            for (int space = 1; space <= n - i; space++) {
                System.out.print(" ");
            }

            // Print stars
            for (int star = 1; star <= i; star++) {
                System.out.print("*");
            }

            System.out.println();
        }
    }
}
