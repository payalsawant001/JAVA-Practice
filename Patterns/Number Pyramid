public class Star {
    public static void main(String[] args) {

        int n = 5;

        for (int i = 1; i <= n; i++) {

            // print spaces
            for (int space = 1; space <= n - i; space++) {
                System.out.print(" ");
            }

            // print numbers
            for (int num = 1; num <= i; num++) {
                System.out.print(i + " ");
            }

            System.out.println();
        }
    }
}
